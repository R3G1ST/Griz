server {
    if ($host = menu-grizzly-lounge.qmbox.ru) {
        return 301 https://$host$request_uri;
    }
    if ($host = grizzly-lounge.qmbox.ru) {
        return 301 https://$host$request_uri;
    }
    if ($host = qmbox.ru) {
        return 301 https://$host$request_uri;
    }
    listen 80;
    server_name qmbox.ru www.qmbox.ru grizzly-lounge.qmbox.ru menu-grizzly-lounge.qmbox.ru;
    return 404;
}

server {
    if ($host = admin-grizzly.qmbox.ru) {
        return 301 https://$host$request_uri;
    }
    listen 80;
    server_name admin-grizzly.qmbox.ru;
    return 404;
}

